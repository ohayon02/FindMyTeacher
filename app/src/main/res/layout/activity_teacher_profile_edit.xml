<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="עריכת ביוגרפיה ופרטים"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#075E54"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="מחיר לשיעור (שעה) *:"
                android:textSize="16sp"
                android:textColor="@android:color/black" />
            <Button
                android:id="@+id/btnGetAiPriceRecommendation"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="המלצת AI 🤖"
                android:textSize="12sp"
                android:textColor="#075E54" />
        </LinearLayout>

        <EditText
            android:id="@+id/etPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="לדוגמה: 150"
            android:inputType="number"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvPriceRecommendation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#555555"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="מיקום בארץ *:"
            android:textSize="16sp"
            android:textColor="@android:color/black" />

        <EditText
            android:id="@+id/etLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="לדוגמה: תל אביב, חיפה..."
            android:inputType="text"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="קצת עליי (ביוגרפיה):"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etBio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ספר על הניסיון שלך, שיטת הלימוד וכו'..."
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="נתונים נוספים:"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etExtraInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="כל דבר אחר שחשוב שהתלמידים ידעו"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:gravity="top"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="שמור שינויים"
            android:backgroundTint="#075E54"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ביטול"
            android:backgroundTint="#888888"
            android:layout_marginTop="8dp"
            android:textColor="@android:color/white" />

    </LinearLayout>
</ScrollView>
